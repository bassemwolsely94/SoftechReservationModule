# ElRezeiky Pharmacy Platform — Environment Variables
# Copy to .env and fill in your values

# Django
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,YOUR_SERVER_IP

# PostgreSQL
PG_NAME=elrezeiky_db
PG_USER=postgres
PG_PASSWORD=your_postgres_password
PG_HOST=localhost
PG_PORT=5432

# Sybase ASE 12.5 (SOFTECH) — READ ONLY
SYBASE_DSN=SOFTECH
SYBASE_USER=your_softech_readonly_user
SYBASE_PASSWORD=your_softech_password

# CORS (React frontend)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://YOUR_SERVER_IP:3000
